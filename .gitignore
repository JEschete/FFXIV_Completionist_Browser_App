# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Coverage and test artifacts
.coverage
.coverage.*
htmlcov/
.pytest_debug.log

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Environment and local config
.env
.env.*
*.local
.launch.json

# Release build script and output
build_release.py
dist/

# Local launcher backups
backups/

# Runtime logs / pid files
*.log
*.pid
*.pid.lock

# SQLite / local data outputs
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal

# Spreadsheet inputs (keep only placeholders/docs)
Spreadsheet/*.xlsx
Spreadsheet/~$*.xlsx

# Editor / OS clutter
.vscode/
.idea/
.DS_Store
Thumbs.db
.claude

# Scraper/browser runtime artifacts
CharacterScraping/.lodestone-browser-profile/
CharacterScraping/__pycache__/
CharacterScraping/*.sqlite
CharacterScraping/*.sqlite-shm
CharacterScraping/*.sqlite-wal
CharacterScraping/ExampleHTMLs/

# Local cache of wiki pages (keep curated references trackable)
GameDataReferences/cache/
# Wiki crawler scratch / resume state
GameDataReferences/_*
# Raw HTML captures from manual scrapes
GameDataReferences/*.html

# Per-character progress sidecars — user data, never committed
data/progress/

# Lodestone probe outputs and diagnostics
data/lodestone_probe/logs/
data/lodestone_probe/import_logs/
data/lodestone_probe/unmatched/
data/lodestone_probe/*_auth_*.json