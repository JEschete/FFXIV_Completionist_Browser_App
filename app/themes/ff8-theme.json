      "muted": { "value": "#49567d", "desc": "Secondary text" },
      "faint": { "value": "#7b85a8", "desc": "Tertiary text" }
    },
    "accents": {
      "accent":    { "value": "#d64ab0", "desc": "Sorceress magenta accent" },
      "accent-dk": { "value": "#8e2e77", "desc": "Pressed magenta" },
      "gold":      { "value": "#b07a17", "desc": "Insignia gold" }
    },
    "crystals": {
      "crystal-earth": { "value": "#56ad58", "desc": "Earth analog" },
      "crystal-fire":  { "value": "#e46054", "desc": "Fire analog" },
      "crystal-water": { "value": "#418fd8", "desc": "Water analog" },
      "crystal-wind":  { "value": "#b57de5", "desc": "Wind analog" }
    },
