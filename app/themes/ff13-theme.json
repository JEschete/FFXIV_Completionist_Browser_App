  "meta": {
    "name": "Cocoon Pulse Protocol (FF13)",
    "id": "ff13-cocoon-pulse-protocol",
    "colorScheme": "dual",
    "defaultScheme": "dark",
    "version": 1,
    "source": "Inspired by Final Fantasy XIII: Cocoon futurism, Pulse wild contrast, and crystallized L'Cie energy",
    "tokenConvention": "Every color key maps to a CSS custom property named --<key>. e.g. \"accent\" -> var(--accent). The group names (surfaces, lines, text, accents, crystals, states) are for human organization only and are NOT part of the variable name. The four crystal-* tokens are extra identity colors; wire them up where supported.",
    "notExportedYet": "Non-color tokens still live only in styles.css and are intentionally omitted here: --radius, --radius-s, --shadow. For stronger FF13 identity, consider holographic edge glints and subtle crystalline noise overlays in interactive regions."
  },
